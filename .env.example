# IMPORTANT: DO NOT hardcode actual secrets here.
# Inject values via HashiCorp Vault or AWS KMS in production environments.
# All data at rest must use AES-256 encryption using keys derived from these KMS references.

# Database
DATABASE_URL="postgresql://testprite:<INJECTED_DB_PASSWORD>@postgres:5432/testprite"

# Messaging
RABBITMQ_URL="amqp://testprite:<INJECTED_MQ_PASSWORD>@rabbitmq:5672"

# Security (AES-256 Secret References)
# Example Vault Path: vault://secret/data/testprite/encryption_key
ENCRYPTION_KEY_REF="<KMS_OR_VAULT_REFERENCE_HERE>"

# Redis
REDIS_URL="redis://redis:6379"

# AI/ML Inference
LLM_INFERENCE_ENDPOINT="<INJECTED_LLM_URL>"
LLM_API_KEY="<INJECTED_LLM_KEY>"
